{
  "kind": "collectionType",
  "collectionName": "lesson_progresses",
  "info": {
    "singularName": "lesson-progress",
    "pluralName": "lesson-progresses",
    "displayName": "LessonProgress"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "intoReadDateTime": {
      "type": "datetime"
    },
    "theoryReadDateTime": {
      "type": "datetime"
    },
